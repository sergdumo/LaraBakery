rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.email in ["serdumo@gmail.com", "saralaracorrea@gmail.com"]
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && userDoc(request.auth.uid).data.role == "admin"
          )
        );
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && (
          request.resource.data.role == "customer"
          || (request.resource.data.role == "admin" && request.auth.token.email in ["serdumo@gmail.com", "saralaracorrea@gmail.com"])
        )
        && request.resource.data.email is string;
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role;
      allow update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.status == "pendiente"
        && request.resource.data.payment_status == "pendiente";
      allow read: if isAdmin() || (signedIn() && resource.data.user_id == request.auth.uid);
      allow update, delete: if isAdmin();
      allow update: if signedIn()
        && resource.data.user_id == request.auth.uid
        && resource.data.status == "pendiente"
        && request.resource.data.user_id == resource.data.user_id
        && request.resource.data.status == resource.data.status
        && request.resource.data.payment_status == resource.data.payment_status;
      allow delete: if signedIn()
        && resource.data.user_id == request.auth.uid
        && resource.data.status == "pendiente";

      match /items/{itemId} {
        allow create: if isAdmin();
        allow create: if signedIn()
          && getAfter(/databases/$(database)/documents/orders/$(orderId)).data.user_id == request.auth.uid
          && getAfter(/databases/$(database)/documents/orders/$(orderId)).data.status == "pendiente";
        allow read: if isAdmin()
          || (signedIn() && get(/databases/$(database)/documents/orders/$(orderId)).data.user_id == request.auth.uid);
        allow update, delete: if isAdmin();
        allow create, update, delete: if signedIn()
          && get(/databases/$(database)/documents/orders/$(orderId)).data.user_id == request.auth.uid
          && get(/databases/$(database)/documents/orders/$(orderId)).data.status == "pendiente";
      }
    }

    match /counters/{counterId} {
      allow read: if signedIn();
      allow write: if isAdmin()
        || (
          signedIn()
          && counterId == "orders"
          && request.resource.data.keys().hasOnly(["date", "count"])
          && request.resource.data.date is string
          && request.resource.data.count is int
          && request.resource.data.count >= 1
        );
    }

    match /product_costs/{costId} {
      allow read, write: if isAdmin();
    }

    match /business_costs/{costId} {
      allow read, write: if isAdmin();
    }
  }
}
